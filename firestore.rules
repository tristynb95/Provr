rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROVR PULSE SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, identity-based security model.
     * Note: In this prototype, we allow unauthenticated writes to key collections 
     * to support the "First-Run Seeding" pattern triggered from the login page.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In this prototype, we prioritize site-specific roles defined in the user document.
      return true; // Simplified for prototype accessibility
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles.
     */
    match /users/{userId} {
      allow read, list, write: if true; 
    }

    /**
     * @description Rules for global admin roles.
     */
    match /app_roles/admins/{adminId} {
      allow get, list, create, update, delete: if true; 
    }

    /**
     * @description Global bakery sites.
     */
    match /sites/{siteId} {
      allow read, write: if true;
    }

    /**
     * @description Global survey templates.
     */
    match /surveys/{surveyId} {
      allow get, list, create, update, delete: if true;

      match /questions/{questionId} {
        allow get, list, create, update, delete: if true;
      }
    }

    /**
     * @description Feedback requests.
     */
    match /feedbackRequests/{feedbackRequestId} {
      allow get, list, create, update, delete: if true;
    }

    /**
     * @description Completed feedback responses.
     */
    match /feedbackResponses/{feedbackResponseId} {
      allow get, list, create, update, delete: if true;

      match /questionResponses/{questionResponseId} {
        allow get, list, create, update, delete: if true;
      }
    }

    /**
     * @description Shower thoughts.
     */
    match /showerThoughts/{showerThoughtId} {
      allow get, list, create, update, delete: if true;
    }

    /**
     * @description Pulse responses.
     */
    match /pulseResponses/{pulseId} {
      allow read, write: if true;
    }
  }
}