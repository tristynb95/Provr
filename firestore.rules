rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROVR PULSE SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, identity-based security model designed for an organizational 
     * feedback platform. It prioritizes "Authorization Independence" by leveraging denormalized 
     * ownership and participant fields, ensuring that security checks are performant and do 
     * not require excessive cross-document lookups.
     *
     * DATA STRUCTURE & HIERARCHY:
     * - /users/{userId}: Private user profiles managed via direct ownership.
     * - /app_roles/admins: A specialized collection for Database Access Control (DBAC) to 
     *   identify global administrators.
     * - /surveys: Publicly readable (authenticated) survey templates with admin-only write access.
     * - /feedback_requests & /feedback_responses: Peer-to-peer and assessment data secured by 
     *   verifying the user is either the requester, responder, or recipient.
     * - /shower_thoughts: Private communication channel between employees and managers.
     * - /sites: Global site directory.
     *
     * KEY SECURITY DECISIONS:
     * 1. Global Admin Role: Administrators are defined by the existence of their UID in 
     *    the /app_roles/admins/ collection.
     * 2. Participant Authorization: For collaborative entities (Feedback, Thoughts), 
     *    authorization is granted if the authenticated UID matches any of the participants 
     *    stored directly on the document (requesterId, recipientId, managerId, etc.).
     * 3. Relational Integrity: On creation, documents must include the correct internal 
     *    references (e.g., creatorId) that match the authenticated user's identity.
     * 4. Structural Segregation: Administrative data (roles) is strictly separated 
     *    from operational data to prevent privilege escalation.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a registered administrator via DBAC. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_roles/admins/$(request.auth.uid));
    }

    /** @description Validates ownership for updates and deletes on an existing document. */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /** @description Verifies if the user is a participant in a shower thought. */
    function isThoughtParticipant(data) {
      return isOwner(data.submitterId) || isOwner(data.managerId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Only the user themselves can manage their data.
     * @path /users/{userId}
     * @allow (get/list) if true (Temporarily allow unauthenticated read for custom login lookup)
     */
    match /users/{userId} {
      allow get, list: if true; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for global admin roles. Read-only for admins; write is restricted (manual/backend setup).
     */
    match /app_roles/admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    /**
     * @description Global bakery sites.
     */
    match /sites/{siteId} {
      allow read: if true; // Allow reading site info for login/seeding
      allow write: if isAdmin();
    }

    /**
     * @description Global survey templates.
     */
    match /surveys/{surveyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /questions/{questionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Feedback requests.
     */
    match /feedback_requests/{feedbackRequestId} {
      allow get: if isSignedIn() && (isOwner(resource.data.requesterId) || isOwner(resource.data.recipientId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.requesterId);
      allow update: if isSignedIn() && (isExistingOwner(resource.data.requesterId) || isExistingOwner(resource.data.recipientId));
      allow delete: if isExistingOwner(resource.data.requesterId);
    }

    /**
     * @description Completed feedback responses.
     */
    match /feedback_responses/{feedbackResponseId} {
      allow get: if isSignedIn() && (isOwner(resource.data.responderId) || isOwner(resource.data.recipientId));
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.responderId);
      allow update: if isExistingOwner(resource.data.responderId);
      allow delete: if isExistingOwner(resource.data.responderId);

      match /question_responses/{questionResponseId} {
        allow get: if isSignedIn() && (isOwner(resource.data.responderId) || isOwner(resource.data.recipientId));
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isOwner(request.resource.data.responderId);
        allow update: if isExistingOwner(resource.data.responderId);
        allow delete: if isExistingOwner(resource.data.responderId);
      }
    }

    /**
     * @description Shower thoughts.
     */
    match /shower_thoughts/{showerThoughtId} {
      allow get: if isSignedIn() && isThoughtParticipant(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.submitterId);
      allow update: if isSignedIn() && (isExistingOwner(resource.data.submitterId) || isExistingOwner(resource.data.managerId));
      allow delete: if isExistingOwner(resource.data.submitterId);
    }
  }
}
